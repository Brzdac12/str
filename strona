          <div>
            <div class="tool-info-name">Mail do klienta</div>
            <div class="tool-info-desc">Oferta, podziękowanie</div>
          </div>
        </div>
      </div>

      <!-- FORMULARZE -->
      <div id="form-post">
        <div class="form-row">
          <div>
            <label>Branża firmy</label>
            <input type="text" id="p-branza" placeholder="np. kawiarnia, sklep odzieżowy"/>
          </div>
          <div>
            <label>Ton komunikacji</label>
            <select id="p-ton">
              <option>Profesjonalny</option>
              <option>Przyjazny i luźny</option>
              <option>Energetyczny</option>
              <option>Elegancki</option>
            </select>
          </div>
        </div>
        <div class="form-group">
          <label>O czym ma być post?</label>
          <textarea id="p-temat" placeholder="np. promocja weekendowa -20% na kawy, nowe menu letnie, otwarcie nowego lokalu..."></textarea>
        </div>
      </div>

      <div id="form-opis" style="display:none">
        <div class="form-row">
          <div>
            <label>Nazwa produktu</label>
            <input type="text" id="o-nazwa" placeholder="np. Bluza z kapturem"/>
          </div>
          <div>
            <label>Cena</label>
            <input type="text" id="o-cena" placeholder="np. 149 zł"/>
          </div>
        </div>
        <div class="form-group">
          <label>Cechy produktu</label>
          <textarea id="o-cechy" placeholder="np. 100% bawełna, dostępna w 5 kolorach, idealna na chłodne dni..."></textarea>
        </div>
      </div>

      <div id="form-opinia" style="display:none">
        <div class="form-group">
          <label>Treść opinii klienta</label>
          <textarea id="op-tresc" placeholder="np. Obsługa super, ale kawa była zimna. Ogólnie ok ale liczę na poprawę."></textarea>
        </div>
        <div class="form-group">
          <label>Ton odpowiedzi</label>
          <select id="op-ton">
            <option>Przepraszający i empatyczny</option>
            <option>Spokojny i rzeczowy</option>
            <option>Ciepły i pozytywny</option>
          </select>
        </div>
      </div>

      <div id="form-email" style="display:none">
        <div class="form-row">
          <div>
            <label>Cel maila</label>
            <select id="e-cel">
              <option>Oferta handlowa</option>
              <option>Podziękowanie za zakup</option>
              <option>Przypomnienie o płatności</option>
              <option>Odpowiedź na zapytanie</option>
            </select>
          </div>
          <div>
            <label>Imię/zwrot do odbiorcy</label>
            <input type="text" id="e-imie" placeholder="np. Panie Marku"/>
          </div>
        </div>
        <div class="form-group">
          <label>Dodatkowe informacje</label>
          <textarea id="e-info" placeholder="np. klient kupił zestaw mebli ogrodowych, chcemy zapytać o satysfakcję..."></textarea>
        </div>
      </div>

      <div class="usage-wrap" id="usage-wrap">
        <div class="usage-label" id="usage-lbl">Użyto 0 z 5 generacji</div>
        <div class="usage-track"><div class="usage-fill" id="usage-fill" style="width:0%"></div></div>
      </div>

      <button class="btn btn-dark" style="margin-top:1rem;width:100%" onclick="generate()">
        Generuj tekst →
      </button>

      <div class="result-wrap" id="result-wrap" style="display:none">
        <div class="loading" id="loading">
          <div class="dot"></div><div class="dot"></div><div class="dot"></div>
          <span>Copylo pisze...</span>
        </div>
        <div class="result-box" id="result-box" style="display:none"></div>
        <div class="result-actions" id="result-actions" style="display:none">
          <button class="btn btn-sm" onclick="copyText()">Kopiuj</button>
          <button class="btn btn-sm" onclick="generate()">Generuj ponownie</button>
        </div>
        <div class="copy-ok" id="copy-ok">Skopiowano do schowka!</div>
        <div class="paywall-card" id="paywall" style="display:none">
          <h3>Limit wyczerpany</h3>
          <p>W planie Starter masz 5 generacji miesięcznie.<br>Przejdź na Pro żeby pisać bez ograniczeń.</p>
          <!--
            ↓↓↓ KROK 2: Tu też wklej swój link Stripe ↓↓↓
          -->
          <a href="TWOJ_LINK_STRIPE" class="btn btn-dark" style="display:block;text-align:center;text-decoration:none;padding:11px;border-radius:var(--radius-sm)">
            Kup Copylo Pro — 20 zł/mies.
          </a>
        </div>
      </div>
    </div>

    <!-- HISTORIA -->
    <div id="pane-hist" class="tab-pane">
      <div id="hist-list"><div class="empty">Brak historii generacji. Zacznij generować teksty!</div></div>
    </div>

    <!-- KONTO -->
    <div id="pane-konto" class="tab-pane">
      <div class="stats">
        <div class="stat">
          <div class="stat-val" id="s-gen">0</div>
          <div class="stat-lbl">Generacji łącznie</div>
        </div>
        <div class="stat">
          <div class="stat-val" id="s-plan">Starter</div>
          <div class="stat-lbl">Aktywny plan</div>
        </div>
        <div class="stat">
          <div class="stat-val" id="s-left">5</div>
          <div class="stat-lbl">Pozostało</div>
        </div>
      </div>
      <div id="konto-upgrade">
        <div class="paywall-card">
          <h3>Przejdź na Copylo Pro</h3>
          <p>Bez limitu generacji, wszystkie narzędzia, pełna historia. Anuluj kiedy chcesz — bez zobowiązań.</p>
          <!--
            ↓↓↓ KROK 2: Tu też wklej swój link Stripe ↓↓↓
          -->
          <a href="TWOJ_LINK_STRIPE" class="btn btn-dark" style="display:block;text-align:center;text-decoration:none;padding:11px;border-radius:var(--radius-sm)">
            Kup Pro — 20 zł/mies.
          </a>
        </div>
      </div>
      <div id="konto-pro" style="display:none">
        <div class="pro-active">
          <h3>Copylo Pro aktywny</h3>
          <p>Bez limitu generacji. Plan odnawia się automatycznie co miesiąc.</p>
        </div>
      </div>
    </div>
  </div>
</div>

<script>
  // ============================================================
  // KROK 1: Wklej swój klucz API Anthropic poniżej
  // Zamień "TWOJ_KLUCZ_API" na klucz ze strony console.anthropic.com
  // Przykład: "sk-ant-api03-abcdef..."
  // UWAGA: Po uruchomieniu strony rozważ przeniesienie klucza
  // na serwer (backend), żeby nie był widoczny publicznie.
  // ============================================================
  const ANTHROPIC_API_KEY = "TWOJ_KLUCZ_API";

  let isPro = false;
  let used = 0;
  const maxFree = 5;
  let curTool = 'post';
  let history = [];
  const toolNames = {
    post: 'Post social media',
    opis: 'Opis produktu',
    opinia: 'Odpowiedź na opinię',
    email: 'Mail do klienta'
  };

  function enterApp(plan) {
    isPro = plan === 'pro';
    document.getElementById('s-land').classList.remove('active');
    document.getElementById('s-app').classList.add('active');
    window.scrollTo(0, 0);
    const pill = document.getElementById('plan-pill');
    pill.textContent = isPro ? 'Pro' : 'Starter';
    pill.className = isPro ? 'pill pro' : 'pill';
    updateUI();
    renderHist();
    document.getElementById('konto-upgrade').style.display = isPro ? 'none' : 'block';
    document.getElementById('konto-pro').style.display = isPro ? 'block' : 'none';
    document.getElementById('s-plan').textContent = isPro ? 'Pro' : 'Starter';
  }

  function backToLand() {
    document.getElementById('s-app').classList.remove('active');
    document.getElementById('s-land').classList.add('active');
    document.getElementById('result-wrap').style.display = 'none';
    window.scrollTo(0, 0);
  }

  function switchTab(t) {
    ['gen', 'hist', 'konto'].forEach((x, i) => {
      document.getElementById('pane-' + x).className = 'tab-pane' + (x === t ? ' active' : '');
      document.querySelectorAll('.tab')[i].className = 'tab' + (x === t ? ' active' : '');
    });
  }

  function pickTool(el, t) {
    document.querySelectorAll('.tool-card').forEach(c => c.classList.remove('selected'));
    el.classList.add('selected');
    curTool = t;
    ['post', 'opis', 'opinia', 'email'].forEach(x => {
      document.getElementById('form-' + x).style.display = x === t ? 'block' : 'none';
    });
    document.getElementById('result-wrap').style.display = 'none';
  }

  function updateUI() {
    const pct = isPro ? 100 : Math.round(Math.min((used / maxFree) * 100, 100));
    document.getElementById('usage-fill').style.width = pct + '%';
    document.getElementById('usage-lbl').textContent = isPro
      ? 'Plan Pro — bez limitu generacji'
      : `Użyto ${used} z ${maxFree} generacji`;
    document.getElementById('s-gen').textContent = used;
    document.getElementById('s-left').textContent = isPro ? '∞' : Math.max(0, maxFree - used);
  }

  function getPrompt() {
    if (curTool === 'post') {
      const b = document.getElementById('p-branza').value || 'firma';
      const t = document.getElementById('p-ton').value;
      const tm = document.getElementById('p-temat').value || 'ogólna promocja';
      return `Napisz angażujący post na Facebook/Instagram dla firmy z branży: ${b}. Ton: ${t}. Temat: ${tm}. Post po polsku, max 3 akapity, dodaj 3-5 emoji i 3-5 hashtagów na końcu. Odpowiedz tylko treścią posta, bez żadnych komentarzy.`;
    } else if (curTool === 'opis') {
      const n = document.getElementById('o-nazwa').value || 'produkt';
      const c = document.getElementById('o-cena').value;
      const f = document.getElementById('o-cechy').value;
      return `Napisz profesjonalny opis produktu "${n}"${c ? ` w cenie ${c}` : ''}.${f ? ' Cechy: ' + f : ''} Opis po polsku, ok 80-100 słów, skupiony na korzyściach dla klienta. Odpowiedz tylko treścią opisu, bez komentarzy.`;
    } else if (curTool === 'opinia') {
      const tr = document.getElementById('op-tresc').value || 'Dobra obsługa, polecam.';
      const t = document.getElementById('op-ton').value;
      return `Napisz odpowiedź na opinię klienta w Google. Opinia: "${tr}". Ton: ${t}. Po polsku, 50-70 słów, naturalna i profesjonalna. Odpowiedz tylko treścią odpowiedzi, bez komentarzy.`;
    } else {
      const cel = document.getElementById('e-cel').value;
      const im = document.getElementById('e-imie').value || 'Szanowny Kliencie';
      const inf = document.getElementById('e-info').value;
      return `Napisz profesjonalny email do klienta. Cel: ${cel}. Zwrot do odbiorcy: ${im}. Kontekst: ${inf || 'brak dodatkowych informacji'}. Po polsku, krótki i konkretny, z uprzejmym pozdrowieniem. Odpowiedz tylko treścią emaila, bez komentarzy.`;
    }
  }

  async function generate() {
    if (!isPro && used >= maxFree) {
      document.getElementById('result-wrap').style.display = 'block';
      document.getElementById('loading').style.display = 'none';
      document.getElementById('result-box').style.display = 'none';
      document.getElementById('result-actions').style.display = 'none';
      document.getElementById('paywall').style.display = 'block';
      return;
    }

    document.getElementById('result-wrap').style.display = 'block';
    document.getElementById('loading').style.display = 'flex';
    document.getElementById('result-box').style.display = 'none';
    document.getElementById('result-actions').style.display = 'none';
    document.getElementById('paywall').style.display = 'none';
    document.getElementById('copy-ok').style.display = 'none';

    try {
      const res = await fetch('https://api.anthropic.com/v1/messages', {
        method: 'POST',
        headers: {
          'Content-Type': 'application/json',
          'x-api-key': ANTHROPIC_API_KEY,
          'anthropic-version': '2023-06-01',
          'anthropic-dangerous-direct-browser-access': 'true'
        },
        body: JSON.stringify({
          model: 'claude-sonnet-4-20250514',
          max_tokens: 1000,
          messages: [{ role: 'user', content: getPrompt() }]
        })
      });

      const data = await res.json();

      if (data.error) {
        throw new Error(data.error.message || 'Błąd API');
      }

      const txt = data.content?.map(b => b.text || '').join('') || 'Błąd — spróbuj ponownie.';

      document.getElementById('loading').style.display = 'none';
      document.getElementById('result-box').style.display = 'block';
      document.getElementById('result-box').textContent = txt;
      document.getElementById('result-actions').style.display = 'flex';

      used++;
      history.unshift({
        type: toolNames[curTool],
        date: new Date().toLocaleTimeString('pl-PL', { hour: '2-digit', minute: '2-digit' }),
        preview: txt.slice(0, 100) + (txt.length > 100 ? '…' : '')
      });
      renderHist();
      updateUI();

    } catch (e) {
      document.getElementById('loading').style.display = 'none';
      document.getElementById('result-box').style.display = 'block';
      document.getElementById('result-box').textContent =
        'Błąd połączenia z AI. Sprawdź czy klucz API jest poprawnie wklejony w pliku index.html i spróbuj ponownie.';
      document.getElementById('result-actions').style.display = 'flex';
    }
  }

  function copyText() {
    const txt = document.getElementById('result-box').textContent;
    navigator.clipboard.writeText(txt).then(() => {
      document.getElementById('copy-ok').style.display = 'block';
      setTimeout(() => document.getElementById('copy-ok').style.display = 'none', 2500);
    }).catch(() => {
      const ta = document.createElement('textarea');
      ta.value = txt;
      document.body.appendChild(ta);
      ta.select();
      document.execCommand('copy');
      document.body.removeChild(ta);
      document.getElementById('copy-ok').style.display = 'block';
      setTimeout(() => document.getElementById('copy-ok').style.display = 'none', 2500);
    });
  }

  function renderHist() {
    const el = document.getElementById('hist-list');
    if (!history.length) {
      el.innerHTML = '<div class="empty">Brak historii generacji. Zacznij generować teksty!</div>';
      return;
    }
    el.innerHTML = history.map(h => `
      <div class="hist-item">
        <div class="hist-top">
          <span class="hist-badge">${h.type}</span>
          <span class="hist-date">${h.date}</span>
        </div>
        <div class="hist-text">${h.preview}</div>
      </div>
    `).join('');
  }
</script>
</body>
</html>
