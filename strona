<!DOCTYPE html>
<html lang="pl">
<head>
<meta charset="UTF-8"/>
<meta name="viewport" content="width=device-width, initial-scale=1.0"/>
<title>Copylo — Profesjonalne teksty AI dla firm</title>
<meta name="description" content="Posty na social media, opisy produktów, odpowiedzi na Google, maile — gotowe w 10 sekund."/>
<style>
  /* ============================================================
     COPYLO — plik gotowy do wgrania na GitHub + Vercel
     
     ZANIM URUCHOMISZ — uzupełnij 2 rzeczy:
     1. Znajdź "TWOJ_KLUCZ_API" i wklej swój klucz Anthropic
     2. Znajdź "TWOJ_LINK_STRIPE" i wklej link płatności ze Stripe
  ============================================================ */

  *, *::before, *::after { box-sizing: border-box; margin: 0; padding: 0; }

  :root {
    --bg: #ffffff;
    --bg2: #f7f6f3;
    --bg3: #f0efe9;
    --text: #1a1a18;
    --text2: #5f5e5a;
    --text3: #9a9990;
    --border: rgba(0,0,0,0.1);
    --border2: rgba(0,0,0,0.18);
    --accent: #2c2c2a;
    --accent-light: #f1efe8;
    --radius: 10px;
    --radius-sm: 7px;
  }

  @media (prefers-color-scheme: dark) {
    :root {
      --bg: #1a1a18;
      --bg2: #232320;
      --bg3: #2c2c28;
      --text: #f1efe8;
      --text2: #9a9990;
      --text3: #636260;
      --border: rgba(255,255,255,0.1);
      --border2: rgba(255,255,255,0.18);
      --accent: #e8e6df;
      --accent-light: #2c2c28;
    }
    .btn-dark { background: #e8e6df !important; color: #1a1a18 !important; }
    .logo-mark { background: #e8e6df !important; }
    .logo-mark svg { stroke: #1a1a18 !important; }
  }

  html { scroll-behavior: smooth; }

  body {
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', system-ui, sans-serif;
    background: var(--bg);
    color: var(--text);
    min-height: 100vh;
    font-size: 16px;
    line-height: 1.6;
  }

  /* TOPBAR */
  .topbar {
    padding: 1rem 1.5rem;
    display: flex;
    align-items: center;
    justify-content: space-between;
    border-bottom: 0.5px solid var(--border);
    position: sticky;
    top: 0;
    background: var(--bg);
    z-index: 100;
  }
  .logo { display: flex; align-items: center; gap: 8px; text-decoration: none; }
  .logo-mark {
    width: 30px; height: 30px;
    background: #2c2c2a;
    border-radius: 7px;
    display: flex; align-items: center; justify-content: center;
  }
  .logo-mark svg { width: 17px; height: 17px; stroke: #f1efe8; fill: none; stroke-width: 1.5; stroke-linecap: round; }
  .logo-name { font-size: 18px; font-weight: 600; color: var(--text); letter-spacing: -0.4px; }
  .logo-name span { color: var(--text3); font-weight: 400; }
  .topbar-right { display: flex; gap: 8px; align-items: center; }
  .pill {
    font-size: 12px; padding: 5px 12px;
    border-radius: 20px;
    border: 0.5px solid var(--border2);
    background: var(--bg2);
    color: var(--text2);
    cursor: pointer;
    text-decoration: none;
    transition: all .15s;
  }
  .pill:hover { background: var(--bg3); }
  .pill.pro { background: var(--accent-light); color: var(--accent); border-color: var(--border2); font-weight: 500; }

  /* SCREEN SYSTEM */
  .screen { display: none; }
  .screen.active { display: block; }

  /* HERO */
  .hero {
    padding: 4rem 1.5rem 3rem;
    text-align: center;
    max-width: 600px;
    margin: 0 auto;
  }
  .hero-eyebrow {
    font-size: 11px;
    letter-spacing: 1.5px;
    text-transform: uppercase;
    color: var(--text3);
    margin-bottom: 1.25rem;
  }
  .hero h1 {
    font-size: clamp(26px, 5vw, 38px);
    font-weight: 600;
    line-height: 1.2;
    letter-spacing: -0.8px;
    color: var(--text);
    margin-bottom: 1rem;
  }
  .hero p {
    font-size: 16px;
    color: var(--text2);
    line-height: 1.7;
    max-width: 420px;
    margin: 0 auto 2.5rem;
  }

  /* FEATURES STRIP */
  .features {
    display: grid;
    grid-template-columns: repeat(auto-fit, minmax(140px, 1fr));
    gap: 8px;
    padding: 0 1.5rem 2.5rem;
    max-width: 640px;
    margin: 0 auto;
  }
  .feat {
    background: var(--bg2);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 1rem;
    text-align: center;
  }
  .feat-icon {
    width: 34px; height: 34px;
    border-radius: 8px;
    background: var(--bg);
    border: 0.5px solid var(--border);
    margin: 0 auto 8px;
    display: flex; align-items: center; justify-content: center;
  }
  .feat-icon svg { width: 16px; height: 16px; stroke: var(--text2); fill: none; stroke-width: 1.5; stroke-linecap: round; }
  .feat-name { font-size: 13px; font-weight: 500; color: var(--text); margin-bottom: 2px; }
  .feat-desc { font-size: 11px; color: var(--text3); line-height: 1.4; }

  /* PLANS */
  .plans {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 12px;
    padding: 0 1.5rem 1rem;
    max-width: 580px;
    margin: 0 auto;
  }
  @media (max-width: 420px) { .plans { grid-template-columns: 1fr; } }
  .plan {
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 1.25rem;
  }
  .plan.featured { border: 1.5px solid var(--accent); }
  .plan-tag {
    font-size: 11px; padding: 2px 9px;
    border-radius: 20px;
    background: var(--accent-light);
    color: var(--accent);
    border: 0.5px solid var(--border2);
    display: inline-block;
    margin-bottom: 10px;
    font-weight: 500;
  }
  .plan-name { font-size: 13px; color: var(--text2); margin-bottom: 6px; }
  .plan-price { font-size: 30px; font-weight: 600; color: var(--text); letter-spacing: -1px; line-height: 1; margin-bottom: 4px; }
  .plan-price sup { font-size: 15px; font-weight: 400; vertical-align: super; letter-spacing: 0; }
  .plan-price sub { font-size: 13px; font-weight: 400; color: var(--text3); letter-spacing: 0; }
  .plan-features { list-style: none; margin: 14px 0 18px; }
  .plan-features li {
    font-size: 13px; color: var(--text2);
    padding: 4px 0;
    display: flex; align-items: center; gap: 8px;
  }
  .chk {
    width: 15px; height: 15px;
    border-radius: 50%;
    flex-shrink: 0;
    display: flex; align-items: center; justify-content: center;
  }
  .chk.on { background: var(--accent); }
  .chk.on::after { content: ''; width: 5px; height: 5px; background: var(--bg); border-radius: 50%; }
  .chk.off { background: var(--border2); border-radius: 50%; }

  /* BUTTONS */
  .btn {
    width: 100%;
    padding: 11px;
    border-radius: var(--radius-sm);
    font-size: 14px;
    font-weight: 500;
    cursor: pointer;
    border: 0.5px solid var(--border2);
    background: var(--bg2);
    color: var(--text);
    transition: all .15s;
    font-family: inherit;
  }
  .btn:hover { background: var(--bg3); }
  .btn-dark {
    background: #2c2c2a;
    color: #f1efe8;
    border-color: #2c2c2a;
  }
  .btn-dark:hover { background: #444441; }
  .btn-sm {
    padding: 8px 16px;
    width: auto;
    font-size: 13px;
  }

  .land-note {
    text-align: center;
    font-size: 12px;
    color: var(--text3);
    padding: 1rem 0 3rem;
  }

  /* APP */
  .app-wrap { padding: 1.25rem 1.5rem; max-width: 680px; margin: 0 auto; }
  .tabs {
    display: flex;
    border-bottom: 0.5px solid var(--border);
    margin-bottom: 1.5rem;
  }
  .tab {
    padding: 9px 16px;
    font-size: 13px;
    color: var(--text2);
    cursor: pointer;
    border-bottom: 2px solid transparent;
    margin-bottom: -0.5px;
    transition: all .15s;
    font-family: inherit;
    background: none;
    border-top: none;
    border-left: none;
    border-right: none;
  }
  .tab.active { color: var(--text); border-bottom-color: var(--accent); font-weight: 500; }
  .tab-pane { display: none; }
  .tab-pane.active { display: block; }

  /* TOOL CARDS */
  .tool-grid {
    display: grid;
    grid-template-columns: repeat(2, 1fr);
    gap: 8px;
    margin-bottom: 1.5rem;
  }
  @media (max-width: 360px) { .tool-grid { grid-template-columns: 1fr; } }
  .tool-card {
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    cursor: pointer;
    transition: all .15s;
    display: flex;
    align-items: center;
    gap: 10px;
  }
  .tool-card:hover { border-color: var(--border2); }
  .tool-card.selected { border-color: var(--accent); background: var(--bg2); }
  .tool-icon-wrap {
    width: 34px; height: 34px;
    border-radius: 7px;
    background: var(--bg2);
    border: 0.5px solid var(--border);
    display: flex; align-items: center; justify-content: center;
    flex-shrink: 0;
    transition: all .15s;
  }
  .tool-card.selected .tool-icon-wrap { background: #2c2c2a; border-color: #2c2c2a; }
  .tool-icon-wrap svg { width: 15px; height: 15px; stroke: var(--text2); fill: none; stroke-width: 1.5; stroke-linecap: round; transition: stroke .15s; }
  .tool-card.selected .tool-icon-wrap svg { stroke: #f1efe8; }
  .tool-info-name { font-size: 13px; font-weight: 500; color: var(--text); }
  .tool-info-desc { font-size: 11px; color: var(--text3); }

  /* FORMS */
  .form-group { margin-bottom: 1rem; }
  .form-row { display: grid; grid-template-columns: 1fr 1fr; gap: 8px; margin-bottom: 1rem; }
  @media (max-width: 400px) { .form-row { grid-template-columns: 1fr; } }
  label { font-size: 13px; color: var(--text2); display: block; margin-bottom: 4px; }
  input[type=text], textarea, select {
    width: 100%;
    padding: 9px 12px;
    border: 0.5px solid var(--border2);
    border-radius: var(--radius-sm);
    background: var(--bg);
    color: var(--text);
    font-size: 14px;
    font-family: inherit;
    outline: none;
    transition: border-color .15s;
  }
  input:focus, textarea:focus, select:focus { border-color: var(--accent); }
  textarea { min-height: 80px; resize: vertical; }
  select { cursor: pointer; }

  /* USAGE */
  .usage-wrap { margin: 1rem 0 0; }
  .usage-label { font-size: 12px; color: var(--text3); margin-bottom: 5px; }
  .usage-track { height: 3px; background: var(--border); border-radius: 2px; overflow: hidden; }
  .usage-fill { height: 100%; background: var(--accent); border-radius: 2px; transition: width .4s; }

  /* RESULT */
  .result-wrap { margin-top: 1rem; }
  .loading {
    display: flex; align-items: center; gap: 8px;
    color: var(--text3); font-size: 13px; padding: .75rem 0;
  }
  .dot {
    width: 5px; height: 5px; border-radius: 50%;
    background: var(--text3);
    animation: pulse 1.2s ease-in-out infinite;
  }
  .dot:nth-child(2) { animation-delay: .2s; }
  .dot:nth-child(3) { animation-delay: .4s; }
  @keyframes pulse {
    0%, 80%, 100% { opacity: .3; transform: scale(.8); }
    40% { opacity: 1; transform: scale(1); }
  }
  .result-box {
    background: var(--bg2);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 1rem;
    font-size: 14px;
    color: var(--text);
    line-height: 1.7;
    white-space: pre-wrap;
    min-height: 80px;
  }
  .result-actions { display: flex; gap: 8px; margin-top: 8px; }
  .copy-ok { font-size: 12px; color: #3b6d11; margin-top: 4px; display: none; }

  /* PAYWALL */
  .paywall-card {
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: var(--radius);
    padding: 1.75rem;
    text-align: center;
    margin-top: 1rem;
  }
  .paywall-card h3 { font-size: 17px; font-weight: 600; margin-bottom: 8px; }
  .paywall-card p { font-size: 14px; color: var(--text2); margin-bottom: 1.25rem; line-height: 1.6; }

  /* STATS */
  .stats { display: grid; grid-template-columns: repeat(3, 1fr); gap: 8px; margin-bottom: 1.5rem; }
  .stat { background: var(--bg2); border-radius: var(--radius-sm); padding: 1rem; text-align: center; }
  .stat-val { font-size: 24px; font-weight: 600; color: var(--text); letter-spacing: -0.5px; }
  .stat-lbl { font-size: 11px; color: var(--text3); margin-top: 2px; }

  /* HISTORY */
  .hist-item {
    background: var(--bg);
    border: 0.5px solid var(--border);
    border-radius: var(--radius-sm);
    padding: 12px 14px;
    margin-bottom: 8px;
  }
  .hist-top { display: flex; justify-content: space-between; align-items: center; margin-bottom: 6px; }
  .hist-badge {
    font-size: 11px; padding: 2px 8px;
    border-radius: 20px;
    background: var(--accent-light);
    color: var(--accent);
    border: 0.5px solid var(--border);
    font-weight: 500;
  }
  .hist-date { font-size: 11px; color: var(--text3); }
  .hist-text { font-size: 13px; color: var(--text2); line-height: 1.5; }

  .empty { font-size: 14px; color: var(--text3); padding: 2rem 0; text-align: center; }

  /* PRO BOX */
  .pro-active {
    background: var(--bg2);
    border-radius: var(--radius);
    padding: 1.5rem;
    text-align: center;
  }
  .pro-active h3 { font-size: 16px; font-weight: 600; margin-bottom: 6px; }
  .pro-active p { font-size: 13px; color: var(--text2); }

  /* FOOTER */
  footer {
    text-align: center;
    padding: 2rem 1.5rem;
    font-size: 12px;
    color: var(--text3);
    border-top: 0.5px solid var(--border);
    margin-top: 2rem;
  }
</style>
</head>
